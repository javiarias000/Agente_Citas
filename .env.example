# =====================================
# ARCADIUM AUTOMATION - CONFIGURACIÓN EXAMPLE
# =====================================
# Copia este archivo a .env y completa los valores

# === Aplicación ===
APP_NAME=Arcadium Automation
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# === WhatsApp API (Evolution API) ===
# URL base de tu instancia Evolution API
WHATSAPP_API_URL=https://evolution-api.example.com
# Token de API (si requiere autenticación)
WHATSAPP_API_TOKEN=your_evolution_api_token
# Nombre de la instancia configurada en Evolution API
WHATSAPP_INSTANCE_NAME=your_instance_name
# Número de admin para notificaciones (formato: 1234567890@s.whatsapp.net)
WHATSAPP_ADMIN_NUMBER=

# === Chatwoot API ===
# URL base de Chatwoot (ej: https://app.chatwoot.com o tu instancia auto-hosted)
CHATWOOT_API_URL=
# Personal Access Token de Chatwoot (Settings → API Tokens)
CHATWOOT_API_TOKEN=
# ID de la cuenta en Chatwoot
CHATWOOT_ACCOUNT_ID=
# ID del inbox (canal) en Chatwoot
CHATWOOT_INBOX_ID=
# Secreto para verificar webhooks (opcional, generar aleatorio)
CHATWOOT_WEBHOOK_SECRET=

# === Base de datos PostgreSQL ===
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/arcadium

# === Memoria / State ===
USE_POSTGRES_FOR_MEMORY=true
MEMORY_TABLE_PREFIX=langchain_memory
SESSION_EXPIRY_HOURS=24

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=
OPENAI_TIMEOUT=30

# === Agente ===
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=false
AGENT_SYSTEM_PROMPT=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Monitoreo ===
ENABLE_METRICS=true
METRICS_PORT=9090

# === Seguridad ===
WEBHOOK_SECRET=generate_a_random_secret_here
CORS_ORIGINS=["*"]

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100

# === Redis (opcional para cache) ===
REDIS_URL=

# =====================================
# MEMORY-AGENT INTEGRATION (OPCIONAL)
# =====================================
# Memoria semántica vectorial a largo plazo
# Más info: INTEGRACION_MEMORY_AGENT.md

# Habilitar integración (false = usar solo PostgreSQLMemory/InMemoryStorage)
USE_MEMORY_AGENT=false

# Tipo de store: 'memory' (InMemoryStore) o 'postgres' (PostgreSQLStore)
MEMORY_AGENT_STORE_TYPE=memory

# URL para PostgreSQLStore (requerido si STORE_TYPE=postgres)
# Ejemplo: postgresql+psycopg://user:pass@localhost:5432/arcadium_memories
MEMORY_AGENT_STORE_URL=

# Modelo de embeddings (formato: provider:model_name)
# OpenAI: openai:text-embedding-3-small (recomendado, barato)
# OpenAI: openai:text-embedding-3-large (mejor calidad, más caro)
# Local: sentence-transformers/all-MiniLM-L6-v2 (gratis, requiere instalar paquete)
MEMORY_AGENT_EMBEDDING_MODEL=openai:text-embedding-3-small

# Configuración de búsqueda
MEMORY_AGENT_MAX_RESULTS=5
MEMORY_AGENT_SIMILARITY_THRESHOLD=0.7

# Extracción automática (experimental, no usar en prod sin tuning)
MEMORY_AGENT_ENABLE_EXTRACTION=false

# Sincronizar memorias con tabla user_profiles.extracted_facts (backup)
MEMORY_AGENT_SYNC_TO_USER_PROFILE=true

