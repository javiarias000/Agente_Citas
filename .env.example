# ============================================
# REQUERIDAS — sin estos valores, la app no inicia
# ============================================

# OpenAI API
OPENAI_API_KEY=sk-...your-key...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/arcadium

# WhatsApp Integration (Evolution API)
WHATSAPP_API_URL=https://evolution-api.example.com
WHATSAPP_INSTANCE_NAME=instance_name
WHATSAPP_API_TOKEN=token_if_needed

# ============================================
# SEGURIDAD — requeridas en producción (DEBUG=false)
# ============================================

DEBUG=false
API_KEY=your-secret-api-key-for-endpoints
WEBHOOK_SECRET=your-webhook-secret-key

# ============================================
# OPCIONAL — Google Calendar Integration
# ============================================

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google_credentials.json
GOOGLE_CALENDAR_DEFAULT_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Guayaquil
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth2callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# OPCIONAL — Chatwoot Integration
# ============================================

CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=

# ============================================
# APLICACIÓN
# ============================================

APP_NAME=Arcadium Automation
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# ============================================
# LANGGRAPH / Agent
# ============================================

USE_LANGGRAPH=true
USE_GRAPH_V2=true
USE_MEMORY_AGENT=false
LANGGRAPH_MODEL=gpt-4o-mini
LANGGRAPH_TEMPERATURE=0.7

# ============================================
# MEMORIA / BASE DE DATOS
# ============================================

USE_POSTGRES_FOR_MEMORY=true
MEMORY_TABLE_PREFIX=langchain_memory
MEMORY_AGENT_STORE_TYPE=memory
MEMORY_AGENT_EMBEDDING_MODEL=openai:text-embedding-3-small
MEMORY_AGENT_SIMILARITY_THRESHOLD=0.7

# ============================================
# REDIS (Opcional para cache)
# ============================================

REDIS_URL=

# ============================================
# MONITOREO
# ============================================

ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# CORS
# ============================================

CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_REQUESTS=100

# ============================================
# LANGCHAIN / LANGSMITH (Tracing)
# ============================================

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=arcadium
