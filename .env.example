# =====================================
# ARCADIUM AUTOMATION - CONFIGURACIÓN EXAMPLE
# =====================================
# Copia este archivo a .env y completa los valores

# === Aplicación ===
APP_NAME=Arcadium Automation
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# === WhatsApp API (Evolution API) ===
# URL base de tu instancia Evolution API
WHATSAPP_API_URL=https://evolution-api.example.com
# Token de API (si requiere autenticación)
WHATSAPP_API_TOKEN=your_evolution_api_token
# Nombre de la instancia configurada en Evolution API
WHATSAPP_INSTANCE_NAME=your_instance_name
# Número de admin para notificaciones (formato: 1234567890@s.whatsapp.net)
WHATSAPP_ADMIN_NUMBER=

# === Base de datos PostgreSQL ===
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/arcadium

# === Memoria / State ===
USE_POSTGRES_FOR_MEMORY=true
MEMORY_TABLE_PREFIX=langchain_memory
SESSION_EXPIRY_HOURS=24

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=
OPENAI_TIMEOUT=30

# === Agente ===
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=false
AGENT_SYSTEM_PROMPT=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Monitoreo ===
ENABLE_METRICS=true
METRICS_PORT=9090

# === Seguridad ===
WEBHOOK_SECRET=generate_a_random_secret_here
CORS_ORIGINS=["*"]

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100

# === Redis (opcional para cache) ===
REDIS_URL=
