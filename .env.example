# =====================================
# ARCADIUM AUTOMATION - CONFIGURACIÓN EXAMPLE
# =====================================
# Copia este archivo a .env y completa los valores

# === Aplicación ===
APP_NAME=Arcadium Automation
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# === WhatsApp API (Evolution API) ===
# URL base de tu instancia Evolution API
WHATSAPP_API_URL=https://evolution-api.example.com
# Token de API (si requiere autenticación)
WHATSAPP_API_TOKEN=your_evolution_api_token
# Nombre de la instancia configurada en Evolution API
WHATSAPP_INSTANCE_NAME=your_instance_name
# Número de admin para notificaciones (formato: 1234567890@s.whatsapp.net)
WHATSAPP_ADMIN_NUMBER=

# === Chatwoot API ===
# URL base de Chatwoot (ej: https://app.chatwoot.com o tu instancia auto-hosted)
CHATWOOT_API_URL=
# Personal Access Token de Chatwoot (Settings → API Tokens)
CHATWOOT_API_TOKEN=
# ID de la cuenta en Chatwoot
CHATWOOT_ACCOUNT_ID=
# ID del inbox (canal) en Chatwoot
CHATWOOT_INBOX_ID=
# Secreto para verificar webhooks (opcional, generar aleatorio)
CHATWOOT_WEBHOOK_SECRET=

# === Base de datos PostgreSQL ===
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/arcadium

# === Memoria / State ===
USE_POSTGRES_FOR_MEMORY=true
MEMORY_TABLE_PREFIX=langchain_memory
SESSION_EXPIRY_HOURS=24

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=
OPENAI_TIMEOUT=30

# === Agente ===
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=false
AGENT_SYSTEM_PROMPT=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Monitoreo ===
ENABLE_METRICS=true
METRICS_PORT=9090

# === Seguridad ===
WEBHOOK_SECRET=generate_a_random_secret_here
CORS_ORIGINS=["*"]

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100

# === Redis (opcional para cache) ===
REDIS_URL=

# === Google Calendar (via Composio MCP) ===
# Obtener en: https://app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=your_composio_api_key
# Tu email o user ID registrado en Composio
COMPOSIO_USER_ID=your_email_or_user_id
# Calendar ID (usa "primary" o el email del calendario específico)
GOOGLE_CALENDAR_DEFAULT_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Guayaquil
# Instrucciones de auth: ejecutar `composio login && composio add googlecalendar`
